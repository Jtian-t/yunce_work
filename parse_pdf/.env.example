# LLM 配置
# 对于火山引擎方舟 / 豆包：
# 1. LLM_BASE_URL 建议使用 OpenAI 兼容地址 https://ark.cn-beijing.volces.com/api/v3
# 2. LLM_ENDPOINT_ID 建议填写方舟控制台创建的推理接入点 ID，例如 ep-2026xxxx
# 3. LLM_MODEL 可留空，或作为非方舟场景的模型名备用
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_ENDPOINT_ID=ep-your-ark-endpoint-id
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60
